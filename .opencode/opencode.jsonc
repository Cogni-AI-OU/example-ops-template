{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".github/skills/AGENTS.md"
  ],
  "provider": {
    "opencode": {
      "options": {}
    }
  },
  "mcp": {
    // Context7 provides remote docs and context lookups during OpenCode sessions.
    "context7": {
      "type": "remote",
