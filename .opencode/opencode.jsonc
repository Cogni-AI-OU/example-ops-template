{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md",
    ".github/skills/AGENTS.md"
  ],
  "agent": {
    "cogni-ai": {
      "mode": "primary",
      "model": "opencode/gemini-3.1-pro",
      "prompt": "{file:../.github/agents/cogni-ai.agent.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      // Keep shell permissions aligned with .vscode/settings.json allowlist and in alphabetical order.
      "permission": {
        "bash": {
          "ansible": "allow",
          "ansible-galaxy": "allow",
          "ansible-playbook": "allow",
          "awk": "allow",
          "continue": "allow",
          "cp": "allow",
          "ex": "allow",
          "gh": "allow",
          "gh pr review": "deny",
          "git": "allow",
          "hexdump": "allow",
          "links": "allow",
          "mawk": "allow",
          "pipx": "allow",
          "pre-commit": "allow",
          "printf": "allow",
          "set": "allow",
          "time": "allow",
          "timeout": "allow",
          "touch": "allow",
          "true": "allow",
          "vim": "allow"
        }
      }
    }
  },
  "provider": {
    "opencode": {
      "options": {},
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
